@{
    var title = ViewData["Title"]?.ToString() ?? "后台管理";
    var path = Context.Request.Path.Value ?? "";
    bool Active(string value) => path.StartsWith(value, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - 杂货铺后台</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="admin-brand" asp-page="/Admin/Index">杂货铺后台</a>
            <nav class="admin-nav">
                <a class="@(Active("/Admin/Index") ? "active" : "")" asp-page="/Admin/Index">控制台</a>
                <a class="@(Active("/Admin/Config") ? "active" : "")" asp-page="/Admin/Config">系统配置</a>
                <a class="@(Active("/Admin/Categories") ? "active" : "")" asp-page="/Admin/Categories">分类管理</a>
                <a class="@(Active("/Admin/Cards") ? "active" : "")" asp-page="/Admin/Cards/Index">卡片管理</a>
                <a class="@(Active("/Admin/Tags") ? "active" : "")" asp-page="/Admin/Tags">标签管理</a>
                <a class="@(Active("/Admin/QrCode") ? "active" : "")" asp-page="/Admin/QrCode">分享二维码</a>
                <a class="@(Active("/Admin/ChangePassword") ? "active" : "")" asp-page="/Admin/ChangePassword">修改密码</a>
            </nav>
            <a class="admin-logout" asp-page="/Admin/Logout">退出登录</a>
        </aside>
        <main class="admin-main">
            <header class="admin-topbar">
                <div>
                    <h1>@title</h1>
                    <span>梦梦杂货铺内容展示系统</span>
                </div>
                <a class="btn btn-sm btn-outline-primary" href="/mobile/login.html" target="_blank">移动端预览</a>
            </header>
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success">@success</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger">@error</div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
