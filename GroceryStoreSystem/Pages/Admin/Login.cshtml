@page
@model GroceryStoreSystem.Pages.Admin.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>后台登录 - 杂货铺后台</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100">
    <main class="card form-card p-4" style="width: 380px;">
        <h1 class="h4 fw-bold mb-1">杂货铺后台</h1>
        <p class="text-secondary mb-4">内容和移动端展示管理</p>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        <form method="post">
            <div class="mb-3">
                <label class="form-label" asp-for="Username">账号</label>
                <input class="form-control" asp-for="Username" autocomplete="username" />
            </div>
            <div class="mb-4">
                <label class="form-label" asp-for="Password">密码</label>
                <input class="form-control" asp-for="Password" type="password" autocomplete="current-password" />
            </div>
            <button class="btn btn-primary w-100" type="submit">登录</button>
        </form>
    </main>
</body>
</html>
