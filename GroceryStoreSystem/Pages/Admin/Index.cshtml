@page
@model GroceryStoreSystem.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "控制台";
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card metric-card p-4">
            <span class="text-secondary">分类数量</span>
            <strong class="display-6">@Model.Stats.CategoryCount</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card metric-card p-4">
            <span class="text-secondary">卡片数量</span>
            <strong class="display-6">@Model.Stats.CardCount</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card metric-card p-4">
            <span class="text-secondary">已发布</span>
            <strong class="display-6">@Model.Stats.PublishedCount</strong>
        </div>
    </div>
</div>

<div class="card table-card">
    <div class="card-body">
        <h2 class="h5 fw-bold">移动端入口</h2>
        <p class="text-secondary mb-2">@Model.ShareUrl</p>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" href="@Model.ShareUrl" target="_blank">打开移动端</a>
            <a class="btn btn-outline-primary" asp-page="/Admin/QrCode" asp-route-shareUrl="@Model.ShareUrl">生成二维码</a>
        </div>
    </div>
</div>
