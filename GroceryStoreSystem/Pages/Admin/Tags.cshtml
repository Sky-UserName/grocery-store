@page
@model GroceryStoreSystem.Pages.Admin.TagsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "标签管理";
}

<div class="row g-4">
    <div class="col-lg-4">
        <form method="post" asp-page-handler="Save" class="card form-card">
            <div class="card-header bg-white fw-bold">新增标签</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.Name">标签名称</label>
                    <input class="form-control" asp-for="Input.Name" />
                </div>
                <div>
                    <label class="form-label" asp-for="Input.Color">颜色</label>
                    <input class="form-control form-control-color" asp-for="Input.Color" type="color" />
                </div>
            </div>
            <div class="card-footer bg-white text-end">
                <button class="btn btn-primary" type="submit">保存</button>
            </div>
        </form>
    </div>
    <div class="col-lg-8">
        <div class="card table-card">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>标签</th>
                            <th>颜色</th>
                            <th class="text-end">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Tags)
                    {
                        <tr>
                            <td><span class="badge" style="background:@(item.Color ?? "#2B6EF5")">@item.Name</span></td>
                            <td><code>@(item.Color ?? "-")</code></td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline">
                                    <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('确认删除该标签？')">删除</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
