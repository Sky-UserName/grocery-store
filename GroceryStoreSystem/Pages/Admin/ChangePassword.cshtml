@page
@model GroceryStoreSystem.Pages.Admin.ChangePasswordModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "修改密码";
}

<form method="post" class="card form-card" style="max-width: 560px;">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label" asp-for="Input.CurrentPassword">原密码</label>
            <input class="form-control" asp-for="Input.CurrentPassword" type="password" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.NewPassword">新密码</label>
            <input class="form-control" asp-for="Input.NewPassword" type="password" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.ConfirmPassword">确认密码</label>
            <input class="form-control" asp-for="Input.ConfirmPassword" type="password" />
        </div>
    </div>
    <div class="card-footer bg-white text-end">
        <button class="btn btn-primary" type="submit">保存新密码</button>
    </div>
</form>
