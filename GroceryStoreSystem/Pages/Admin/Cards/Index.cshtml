@page
@using GroceryStoreSystem.Models
@model GroceryStoreSystem.Pages.Admin.Cards.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "卡片管理";
}

<div class="card table-card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">分类</label>
                <select class="form-select" asp-for="CategoryId">
                    <option value="">全部分类</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">状态</label>
                <select class="form-select" asp-for="Status">
                    <option value="">全部状态</option>
                    <option value="0">草稿</option>
                    <option value="1">已发布</option>
                    <option value="2">隐藏</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">关键词</label>
                <input class="form-control" asp-for="Keyword" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-outline-primary flex-fill" type="submit">筛选</button>
                <a class="btn btn-primary flex-fill" asp-page="/Admin/Cards/Edit">新增</a>
            </div>
        </form>
    </div>
</div>

<div class="card table-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>封面</th>
                    <th>标题</th>
                    <th>分类</th>
                    <th>标签</th>
                    <th>状态</th>
                    <th>排序</th>
                    <th class="text-end">操作</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var card in Model.Cards)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(card.CoverImageUrl))
                        {
                            <img class="cover-thumb" src="@card.CoverImageUrl" alt="@card.Title" />
                        }
                    </td>
                    <td>
                        <div class="fw-semibold">@card.Title</div>
                        <small class="text-secondary">@card.Summary</small>
                    </td>
                    <td>@card.CategoryName</td>
                    <td>@card.Tags</td>
                    <td><span class="badge @(card.Status == CardStatus.Published ? "text-bg-success" : card.Status == CardStatus.Hidden ? "text-bg-secondary" : "text-bg-warning")">@CardStatus.Label(card.Status)</span></td>
                    <td>@card.SortOrder</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Cards/Edit" asp-route-id="@card.Id">编辑</a>
                        <form method="post" asp-page-handler="Publish" asp-route-id="@card.Id" class="d-inline">
                            <button class="btn btn-sm btn-outline-success" type="submit">发布</button>
                        </form>
                        <form method="post" asp-page-handler="Hide" asp-route-id="@card.Id" class="d-inline">
                            <button class="btn btn-sm btn-outline-secondary" type="submit">隐藏</button>
                        </form>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@card.Id" class="d-inline">
                            <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('确认删除该卡片？')">删除</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
