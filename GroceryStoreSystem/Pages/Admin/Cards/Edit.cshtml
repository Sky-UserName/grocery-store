@page
@using GroceryStoreSystem.Models
@model GroceryStoreSystem.Pages.Admin.Cards.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.Input.Id == 0 ? "新增卡片" : "编辑卡片";
}

<form method="post" class="card form-card" id="cardForm">
    <div class="card-body">
        <input type="hidden" asp-for="Input.Id" />
        <input type="hidden" asp-for="Input.CoverImageUrl" id="coverImageUrl" />
        <textarea asp-for="Input.ContentHtml" id="contentHtml" hidden></textarea>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label" asp-for="Input.CategoryId">分类</label>
                <select class="form-select" asp-for="Input.CategoryId">
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="Input.Title">标题</label>
                <input class="form-control" asp-for="Input.Title" />
            </div>
            <div class="col-md-2">
                <label class="form-label" asp-for="Input.SortOrder">排序</label>
                <input class="form-control" asp-for="Input.SortOrder" type="number" />
            </div>
            <div class="col-md-2">
                <label class="form-label" asp-for="Input.Status">状态</label>
                <select class="form-select" asp-for="Input.Status">
                    <option value="@CardStatus.Draft">草稿</option>
                    <option value="@CardStatus.Published">已发布</option>
                    <option value="@CardStatus.Hidden">隐藏</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label" asp-for="Input.Summary">简介</label>
                <input class="form-control" asp-for="Input.Summary" />
            </div>
            <div class="col-md-7">
                <label class="form-label" asp-for="Input.TagsText">标签</label>
                <input class="form-control" asp-for="Input.TagsText" placeholder="多个标签用逗号分隔" />
            </div>
            <div class="col-md-5">
                <label class="form-label">封面图</label>
                <div class="d-flex gap-3 align-items-center">
                    <img class="cover-thumb" id="coverPreview" src="@(Model.Input.CoverImageUrl ?? "")" alt="" />
                    <input class="form-control" type="file" id="coverUpload" accept="image/*" />
                </div>
            </div>
            <div class="col-12">
                <label class="form-label">详情内容</label>
                <div class="rich-toolbar">
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-command="bold">加粗</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-command="italic">斜体</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-command="insertUnorderedList">列表</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="linkButton">链接</button>
                    <label class="btn btn-sm btn-outline-primary mb-0">
                        插入图片 <input type="file" id="contentImageUpload" accept="image/*" hidden />
                    </label>
                </div>
                <div class="rich-editor" id="richEditor" contenteditable="true">@Html.Raw(Model.Input.ContentHtml)</div>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white d-flex justify-content-between">
        <a class="btn btn-outline-secondary" asp-page="/Admin/Cards/Index">返回</a>
        <button class="btn btn-primary" type="submit">保存卡片</button>
    </div>
</form>

@section Scripts {
    <script>
        const form = document.getElementById('cardForm');
        const editor = document.getElementById('richEditor');
        const contentHtml = document.getElementById('contentHtml');
        const coverUpload = document.getElementById('coverUpload');
        const coverImageUrl = document.getElementById('coverImageUrl');
        const coverPreview = document.getElementById('coverPreview');
        const contentImageUpload = document.getElementById('contentImageUpload');

        document.querySelectorAll('[data-command]').forEach(button => {
            button.addEventListener('click', () => {
                document.execCommand(button.dataset.command, false);
                editor.focus();
            });
        });

        document.getElementById('linkButton').addEventListener('click', () => {
            const url = prompt('请输入链接');
            if (url) document.execCommand('createLink', false, url);
        });

        async function uploadImage(file, usageType) {
            const data = new FormData();
            data.append('file', file);
            data.append('usageType', usageType);
            const response = await fetch('/api/admin/uploads/image', { method: 'POST', body: data });
            if (!response.ok) throw new Error('上传失败');
            return await response.json();
        }

        coverUpload.addEventListener('change', async () => {
            if (!coverUpload.files.length) return;
            const result = await uploadImage(coverUpload.files[0], 'cover');
            coverImageUrl.value = result.url;
            coverPreview.src = result.url;
        });

        contentImageUpload.addEventListener('change', async () => {
            if (!contentImageUpload.files.length) return;
            const result = await uploadImage(contentImageUpload.files[0], 'content');
            document.execCommand('insertHTML', false, `<figure><img src="${result.url}" alt=""><figcaption>图片说明</figcaption></figure>`);
            contentImageUpload.value = '';
        });

        form.addEventListener('submit', () => {
            contentHtml.value = editor.innerHTML;
        });
    </script>
}
